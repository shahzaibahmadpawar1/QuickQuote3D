# Put `.env.local` at the REPOSITORY ROOT (same folder as the top-level README / package.json).
# The Next app lives in `app/` but loads env from the parent directory (see envDir in app/next.config.ts).
#
# Supabase (Dashboard → Project Settings → API)
# Never commit real keys. Do not use the Postgres password in the browser.
NEXT_PUBLIC_SUPABASE_URL=xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx

# Optional: server-only service role for admin portal API routes (never expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY=xxx
